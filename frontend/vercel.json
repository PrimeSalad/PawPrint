{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://pawprint-b0ao.onrender.com/:path*" }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "routes": [
    { "src": "/test", "dest": "/index.html" },
    { "src": "/about", "dest": "/index.html" },
    { "src": "/team", "dest": "/index.html" },
    { "src": "/scan", "dest": "/index.html" }
  ]
}
